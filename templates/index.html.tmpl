{{define "title"}}{{.SiteTitle}}{{end}}
{{define "content"}}
  <h1>{{.SiteTitle}}</h1>

  <div class="recipe-list">
    {{range .Recipes}}
    <a href="/{{.Slug}}/" class="recipe-entry">
      {{if .HasImage}}
      <img src="/{{.Slug}}/image.webp" alt="" class="recipe-thumb" loading="lazy">
      {{end}}
      <div>
        <h2>{{.Name}}</h2>
        <time datetime="{{.DateISO}}">{{.DateFormatted}}</time>
      </div>
    </a>
    {{end}}
  </div>
{{end}}
