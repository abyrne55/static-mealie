{{define "title"}}{{.Recipe.Name}} &mdash; {{.SiteTitle}}{{end}}
{{define "content"}}
  <a href="/" class="back-link">&larr; All recipes</a>
  <article>
    <h1>{{.Recipe.Name}}</h1>
    <p class="recipe-meta">
      <time datetime="{{.Recipe.DateISO}}">{{.Recipe.DateFormatted}}</time>
       &middot; <a href="/{{.Recipe.Slug}}/recipe.md">View as Markdown</a>
    </p>
    {{if .Recipe.HasImage}}
      <img src="/{{.Recipe.Slug}}/image.webp" alt="{{.Recipe.Name}}" class="recipe-image">
    {{end}}
    {{if .Recipe.Description}}<p>{{md .Recipe.Description}}</p>{{end}}
    <div class="recipe-details">
    {{if .Recipe.RecipeYield}}<div class="recipe-detail"><span class="detail-label">Servings</span><span class="detail-value">{{.Recipe.RecipeYield}}</span></div>{{end}}
    {{if .Recipe.PrepTime}}<div class="recipe-detail"><span class="detail-label">Prep Time</span><span class="detail-value">{{.Recipe.PrepTime}}</span></div>{{end}}
    {{if .Recipe.CookTime}}<div class="recipe-detail"><span class="detail-label">Cook Time</span><span class="detail-value">{{.Recipe.CookTime}}</span></div>{{end}}
    {{if .Recipe.PerformTime}}<div class="recipe-detail"><span class="detail-label">Active Time</span><span class="detail-value">{{.Recipe.PerformTime}}</span></div>{{end}}
    {{if .Recipe.TotalTime}}<div class="recipe-detail"><span class="detail-label">Total Time</span><span class="detail-value">{{.Recipe.TotalTime}}</span></div>{{end}}
    </div>
    <h2>Ingredients</h2>
    <ul>
    {{range .Recipe.Ingredients}}
      {{if .IsHeading}}
    </ul>
    <h3>{{.Heading}}</h3>
    <ul>
      {{else if .Display}}
        <li><input type="checkbox"> {{md .Display}}</li>
      {{else}}
        <li><input type="checkbox"> {{if .AmountStr}}{{.AmountStr}} {{end}}{{if .FoodStr}}<strong>{{.FoodStr}}</strong>{{end}}{{if .NoteStr}}<span class="ingredient-note">{{.NoteStr}}</span>{{end}}</li>
      {{end}}
    {{end}}
    </ul>

    <h2>Instructions</h2>
    <ol>
    {{range .Recipe.Instructions}}
      {{if .Title}}
    </ol>
    <h3>{{.Title}}</h3>
    <ol>
      {{end}}
      {{if .Summary}}<li><strong>{{.Summary}}</strong><br>{{md .Text}}</li>
      {{else}}<li>{{md .Text}}</li>
      {{end}}
    {{end}}
    </ol>

    {{if .Recipe.Notes}}
    <h2>Notes</h2>
    {{range .Recipe.Notes}}
      {{if .Title}}<h3>{{.Title}}</h3>{{end}}
      <p>{{md .Text}}</p>
    {{end}}
    {{end}}
  </article>

  {{.JSONLD}}
{{end}}
